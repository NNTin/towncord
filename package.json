{
  "name": "towncord",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run -w @towncord/public-animation-contracts generate",
    "dev:frontend": "npm run assets:public && npm run -w @towncord/frontend dev",
    "build:frontend": "npm run assets:public && npm run -w @towncord/frontend build",
    "typecheck:frontend": "npm run -w @towncord/frontend typecheck",
    "assets:dry": "npm run -w @towncord/public-assets export:dry",
    "assets:public": "npm run -w @towncord/public-assets export:public",
    "assets:bloomseed:dry": "npm run -w @towncord/bloomseed-assets export:dry",
    "assets:bloomseed:public": "npm run -w @towncord/bloomseed-assets export:public",
    "assets:bloomseed:all": "npm run -w @towncord/bloomseed-assets export:all",
    "assets:debug:dry": "npm run -w @towncord/debug-assets export:dry",
    "assets:debug:public": "npm run -w @towncord/debug-assets export:public",
    "assets:debug:all": "npm run -w @towncord/debug-assets export:all",
    "assets:donarg:dry": "npm run -w @towncord/donarg-office-assets export:dry",
    "assets:donarg:public": "npm run -w @towncord/donarg-office-assets export:public",
    "assets:donarg:all": "npm run -w @towncord/donarg-office-assets export:all",
    "build": "echo \"Define workspace build scripts\"",
    "dev": "echo \"Define workspace dev scripts\"",
    "knip": "knip --include files,dependencies,exports,types --include-entry-exports --reporter compact --treat-config-hints-as-errors",
    "test": "echo \"Define workspace tests\"",
    "test:automation": "node --test .github/scripts/__tests__/*.test.mjs"
  },
  "devDependencies": {
    "knip": "5.86.0"
  }
}
