{
  "name": "@towncord/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "assets:public": "npm run -w @towncord/public-assets export:public",
    "contracts:generate": "npm run -w @towncord/public-animation-contracts generate",
    "dev": "npm run contracts:generate && npm run dev:app",
    "dev:app": "vite",
    "build": "npm run contracts:generate && npm run build:app",
    "build:app": "npm run typecheck && vite build",
    "typecheck": "npm run contracts:generate && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview",
    "test": "npm run contracts:generate && vitest run"
  },
  "dependencies": {
    "@towncord/public-animation-contracts": "*",
    "phaser": "^3.90.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  }
}
